ptp_read_ident body i len =
  match i >= len
    true -> i
    _ ->
      c = glyph_str_char_at(body, i)
      is_alpha = c >= 65 && c <= 90 || c >= 97 && c <= 122
      is_digit = c >= 48 && c <= 57
      is_under = c == 95
      match is_alpha || is_digit || is_under
        true -> ptp_read_ident(body, i + 1, len)
        _ -> i
