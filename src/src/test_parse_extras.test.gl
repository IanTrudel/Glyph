test_parse_extras u =
  src = "f u = \\y -> y + 1"
  toks = tokenize(src)
  ast = []
  r = parse_fn_def(src, toks, 0, ast)
  assert(r.node >= 0)
  src2 = r"""f r = \{a: 1, b: 2}"""
  toks2 = tokenize(src2)
  ast2 = []
  r2 = parse_fn_def(src2, toks2, 0, ast2)
  assert(r2.node >= 0)
  src3 = r"""f s = "hello {42}""""
  toks3 = tokenize(src3)
  ast3 = []
  r3 = parse_fn_def(src3, toks3, 0, ast3)
  assert(r3.node >= 0)
  0
