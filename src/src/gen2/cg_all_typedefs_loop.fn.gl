cg_all_typedefs_loop struct_map i =
  match i >= glyph_array_len(struct_map)
    true -> "\n"
    _ ->
      entry = struct_map[i]
      name = entry[0]
      fields = entry[1]
      types = entry[2]
      body = cg_struct_fields(fields, types, 0)
      lb = cg_lbrace()
      rb = cg_rbrace()
      td = s7("typedef struct ", lb, " ", body, s2(rb, " Glyph_"), name, ";\n")
      s2(td, cg_all_typedefs_loop(struct_map, i + 1))
