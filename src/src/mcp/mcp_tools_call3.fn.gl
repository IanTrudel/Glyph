mcp_tools_call3 db_path id pool args_idx tool_name =
  match str_eq(tool_name, "init")
    true -> mcp_tool_init(db_path, id, pool, args_idx)
    _ -> match str_eq(tool_name, "migrate")
      true -> mcp_tool_migrate(db_path, id, pool, args_idx)
      _ -> match str_eq(tool_name, "build")
        true -> mcp_tool_build(db_path, id, pool, args_idx)
        _ -> match str_eq(tool_name, "run")
          true -> mcp_tool_run(db_path, id, pool, args_idx)
          _ -> match str_eq(tool_name, "link")
            true -> mcp_tool_link(db_path, id, pool, args_idx)
            _ -> match str_eq(tool_name, "use")
              true -> mcp_tool_use(db_path, id, pool, args_idx)
              _ -> match str_eq(tool_name, "unuse")
                true -> mcp_tool_unuse(db_path, id, pool, args_idx)
                _ -> match str_eq(tool_name, "libs")
                  true -> mcp_tool_libs(db_path, id, pool, args_idx)
                  _ -> mcp_error(id, 0 - 32602, s2("Unknown tool: ", tool_name))

