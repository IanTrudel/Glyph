mcp_tool_unuse db_path id pool args =
  db = json_get_str(pool, args, "db")
  lib = json_get_str(pool, args, "lib")
  self = glyph_args()[0]
  log_path = "/tmp/glyph_mcp_unuse.txt"
  cmd = s5(self, " unuse ", db, " ", s2(lib, s3(" > ", log_path, " 2>&1")))
  exit_code = glyph_system(cmd)
  out = glyph_read_file(log_path)
  match exit_code == 0
    true -> mcp_text_result(id, out)
    _ -> mcp_text_result(id, s2("UNUSE FAILED\n", out))

