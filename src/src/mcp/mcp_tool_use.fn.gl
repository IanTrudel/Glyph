mcp_tool_use db_path id pool args =
  db = json_get_str(pool, args, "db")
  lib = json_get_str(pool, args, "lib")
  ns_arg = json_get_str(pool, args, "ns")
  ns_flag = match glyph_str_len(ns_arg) > 0
    true -> s2(" --ns=", ns_arg)
    _ -> ""
  self = glyph_args()[0]
  log_path = "/tmp/glyph_mcp_use.txt"
  cmd = s6(self, " use ", db, " ", lib, s3(ns_flag, " > ", s2(log_path, " 2>&1")))
  exit_code = glyph_system(cmd)
  out = glyph_read_file(log_path)
  match exit_code == 0
    true -> mcp_text_result(id, out)
    _ -> mcp_text_result(id, s2("USE FAILED\n", out))

