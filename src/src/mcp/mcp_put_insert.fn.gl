mcp_put_insert name kind body gen ns =
  sb = sb_new()
  sb_append(sb, "INSERT INTO def (name, kind, body, gen, hash, tokens, ns) VALUES ('")
  sb_append(sb, sql_escape(name))
  sb_append(sb, "', '")
  sb_append(sb, sql_escape(kind))
  sb_append(sb, "', '")
  sb_append(sb, sql_escape(body))
  sb_append(sb, "', ")
  sb_append(sb, int_to_str(gen))
  sb_append(sb, ", zeroblob(32), 0, '")
  sb_append(sb, sql_escape(ns))
  sb_append(sb, "')")
  sb_build(sb)
