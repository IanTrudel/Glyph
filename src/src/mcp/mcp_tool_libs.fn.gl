mcp_tool_libs db_path id pool args =
  db = json_get_str(pool, args, "db")
  self = glyph_args()[0]
  log_path = "/tmp/glyph_mcp_libs.txt"
  cmd = s4(self, " libs ", db, s3(" > ", log_path, " 2>&1"))
  exit_code = glyph_system(cmd)
  out = glyph_read_file(log_path)
  match exit_code == 0
    true -> mcp_text_result(id, out)
    _ -> mcp_text_result(id, s2("LIBS FAILED\n", out))

