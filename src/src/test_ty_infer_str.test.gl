test_ty_infer_str u =
  eng = mk_engine()
  q = "\""
  src = s3("f u = ", q, s2("hi", q))
  toks = tokenize(src)
  ast = []
  r = parse_fn_def(src, toks, 0, ast)
  ty = infer_fn_def(eng, ast, r.node)
  pool = eng.ty_pool
  node = pool[ty]
  assert_eq(node.tag, ty_fn())
  ret = pool[node.n2]
  assert_eq(ret.tag, ty_str())
  0
