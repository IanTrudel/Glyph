ctr_add_new found all_apps i =
  match i >= glyph_array_len(found)
    true -> 0
    _ ->
      app = found[i]
      match app_already_seen(all_apps, app.ta_concrete, 0)
        true -> ctr_add_new(found, all_apps, i + 1)
        _ ->
          glyph_array_push(all_apps, app)
          ctr_add_new(found, all_apps, i + 1)
