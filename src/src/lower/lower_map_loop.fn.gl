lower_map_loop ctx ast pairs i map_op =
  match i >= glyph_array_len(pairs)
    true -> 0
    _ ->
      key_op = lower_expr(ctx, ast, pairs[i])
      val_op = lower_expr(ctx, ast, pairs[i + 1])
      tmp = mir_alloc_local(ctx, "")
      mir_emit_call(ctx, tmp, mk_op_func("hm_set"), [map_op, key_op, val_op])
      lower_map_loop(ctx, ast, pairs, i + 2, map_op)

