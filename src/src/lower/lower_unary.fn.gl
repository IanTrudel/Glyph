lower_unary ctx ast node =
  operand = lower_expr(ctx, ast, node.n1)
  mop = lower_unop(node.ival)
  dest = mir_alloc_local(ctx, "")
  mir_emit_unop(ctx, dest, mop, operand)
  _ = match mop == mir_neg()
    true -> match op_type(ctx, operand) == 3
      true -> mir_set_lt(ctx, dest, 3)
      _ -> 0
    _ -> 0
  mk_op_local(dest)
