cmd_update argv argc =
  argv0 = glyph_args()[0]
  cur = glyph_version(0)
  println(s2("Current version: ", cur))
  println("Fetching latest release...")
  rel = update_fetch_release(glyph_repo(0))
  match glyph_str_eq(rel.version, "")
    true ->
      eprintln("Error: could not fetch release info. Check your internet connection.")
      1
    _ ->
      match glyph_str_eq(rel.version, cur)
        true ->
          println(s2("Already up to date: ", cur))
          0
        _ ->
          println(s4("Updating ", cur, " -> ", rel.version))
          match glyph_str_eq(rel.url, "")
            true ->
              eprintln("Error: no linux-x86_64 asset found in release.")
              1
            _ ->
              tarball = "/tmp/glyph-update.tar.gz"
              extract_dir = "/tmp/glyph-update-extract"
              glyph_system(s3("curl -fSL ", rel.url, s2(" -o ", tarball)))
              glyph_system(s4("rm -rf ", extract_dir, " && mkdir -p ", extract_dir))
              glyph_system(s4("tar -xzf ", tarball, " -C ", extract_dir))
              glyph_system(s4("cp ", extract_dir, "/glyph ", s2(argv0, ".new")))
              glyph_system(s4("chmod 755 ", argv0, ".new", ""))
              glyph_system(s4("mv ", argv0, ".new ", argv0))
              glyph_system(s2("mkdir -p $HOME/.claude/skills/glyph && cp ", s2(extract_dir, "/skills/* $HOME/.claude/skills/glyph/")))
              println(s2("Updated to ", rel.version))
              0
