link_warn_bare rows i n =
  match i >= n
    true -> 0
    _ ->
      row = rows[i]
      ns = row[4]
      rest = link_warn_bare(rows, i + 1, n)
      match glyph_str_len(ns) == 0
        true ->
          _ = eprintln(s3("warning: bare name '", row[0], "' has no namespace"))
          rest + 1
        _ -> rest
