is_runtime_fn5 name =
  match name
    _ ? glyph_str_eq(name, "hm_new") -> 1
    _ ? glyph_str_eq(name, "hm_set") -> 1
    _ ? glyph_str_eq(name, "hm_get") -> 1
    _ ? glyph_str_eq(name, "hm_del") -> 1
    _ ? glyph_str_eq(name, "hm_keys") -> 1
    _ ? glyph_str_eq(name, "hm_len") -> 1
    _ ? glyph_str_eq(name, "hm_has") -> 1
    _ -> 0

