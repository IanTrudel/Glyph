mir_pp_op op =
  k = op.okind
  match k
    _ ? k == 1 -> s2("_", itos(op.oval))
    _ ? k == 2 -> itos(op.oval)
    _ ? k == 3 -> match op.oval == 1
      true -> "true"
      _ -> "false"
    _ ? k == 4 -> s3("\"", op.ostr, "\"")
    _ ? k == 5 -> "()"
    _ ? k == 6 -> s2("fn:", op.ostr)
    _ ? k == 7 -> s2("ext:", op.ostr)
    _ -> s2("?op:", itos(k))
