pte_read_name s i =
  len = glyph_str_len(s)
  match i >= len
    true -> i
    _ ->
      c = glyph_str_char_at(s, i)
      is_alpha = c >= 65 && c <= 90 || c >= 97 && c <= 122
      is_digit = c >= 48 && c <= 57
      is_under = c == 95
      match is_alpha || is_digit || is_under
        true -> pte_read_name(s, i + 1)
        _ -> i
