ty_fields_contain_var eng field_ns i var =
  match i >= glyph_array_len(field_ns)
    true -> false
    _ ->
      fi = field_ns[i]
      fnode = pool_get(eng, fi)
      _ = fnode.tag
      match ty_contains_var(eng, fnode.n1, var)
        true -> true
        _ -> ty_fields_contain_var(eng, field_ns, i + 1, var)

