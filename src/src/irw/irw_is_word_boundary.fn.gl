irw_is_word_boundary body i =
  len = glyph_str_len(body)
  match i < 0 || i >= len
    true -> true
    _ ->
      c = glyph_str_char_at(body, i)
      is_alpha = c >= 65 && c <= 90 || c >= 97 && c <= 122
      is_digit = c >= 48 && c <= 57
      is_under = c == 95
      match is_alpha || is_digit || is_under
        true -> false
        _ -> true
