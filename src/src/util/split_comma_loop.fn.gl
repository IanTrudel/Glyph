split_comma_loop s start i result =
  len = glyph_str_len(s)
  match i >= len
    true ->
      glyph_array_push(result, glyph_str_slice(s, start, i))
      result
    _ ->
      ch = glyph_str_char_at(s, i)
      match ch == 44
        true ->
          glyph_array_push(result, glyph_str_slice(s, start, i))
          split_comma_loop(s, i + 1, i + 1, result)
        _ -> split_comma_loop(s, start, i + 1, result)
