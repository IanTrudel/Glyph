test_math u =
  assert_eq(float_to_int(sin(int_to_float(0))), 0)
  assert_eq(float_to_int(cos(int_to_float(0))), 1)
  assert_eq(float_to_int(sqrt(int_to_float(4))), 2)
  assert_eq(float_to_int(pow(int_to_float(2), int_to_float(10))), 1024)
  assert_eq(float_to_int(fabs(str_to_float("-5.0"))), 5)
  assert_eq(float_to_int(floor(str_to_float("3.9"))), 3)
  assert_eq(float_to_int(ceil(str_to_float("3.1"))), 4)
  assert_eq(float_to_int(atan2(int_to_float(0), int_to_float(1))), 0)
  0
