sql_escape_loop s pos len sb =
  match pos < len
    true ->
      c = str_char_at(s, pos)
      match c == 39
        true ->
          sb_append(sb, "''")
          sql_escape_loop(s, pos + 1, len, sb)
        _ ->
          sb_append(sb, str_slice(s, pos, pos + 1))
          sql_escape_loop(s, pos + 1, len, sb)
    _ -> sb_build(sb)
