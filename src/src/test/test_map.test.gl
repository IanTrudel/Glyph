test_map u =
  m = {{"a": 10, "b": 20, "c": 30}}
  assert_eq(hm_len(m), 3)
  assert_eq(hm_get(m, "a"), 10)
  assert_eq(hm_get(m, "b"), 20)
  assert_eq(hm_get(m, "c"), 30)
  assert_eq(hm_get(m, "missing"), 0)
  _ = hm_set(m, "a", 99)
  assert_eq(hm_get(m, "a"), 99)
  assert_eq(hm_len(m), 3)
  _ = hm_set(m, "d", 40)
  assert_eq(hm_len(m), 4)
  assert_eq(hm_has(m, "b"), 1)
  assert_eq(hm_has(m, "x"), 0)
  _ = hm_del(m, "b")
  assert_eq(hm_len(m), 3)
  assert_eq(hm_has(m, "b"), 0)
  empty = {{}}
  assert_eq(hm_len(empty), 0)
  assert_eq(hm_has(empty, "x"), 0)
  0

