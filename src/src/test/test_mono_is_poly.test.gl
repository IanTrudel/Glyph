test_mono_is_poly u =
  src_id = "identity x = x"
  src_main = "main = println(int_to_str(identity(42)))"
  parsed = parse_all_fns([src_id, src_main], 0)
  eng = mk_engine()
  register_builtins(eng)
  tc_pre_register(eng, parsed, 0)
  tc_results = tc_infer_loop(eng, parsed, 0, [])
  is_p = mono_is_poly(parsed, tc_results, eng, "identity")
  is_p2 = mono_is_poly(parsed, tc_results, eng, "main")
  assert_eq(is_p, 1)
  assert_eq(is_p2, 0)
