test_match_field_in_callee u =
  -- x=0, y=1: if offset-0 bug, classify_point reads x not y
  assert_str_eq(classify_point({x: 99, y: 0}), "origin")
  assert_str_eq(classify_point({x: 99, y: 1}), "unit")
  assert_str_eq(classify_point({x: 0,  y: 5}), "other")
  -- The last case is critical: x=0 would match "origin" if reading offset 0
  0
