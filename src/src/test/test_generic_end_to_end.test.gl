test_generic_end_to_end u =
  params_a = []
  glyph_array_push(params_a, "A")
  glyph_array_push(params_a, "B")
  gtd = {gtd_name: "Pair", gtd_params: params_a, gtd_body: "\{fst:A,snd:B}"}
  args_int_str = []
  glyph_array_push(args_int_str, "Int")
  glyph_array_push(args_int_str, "Str")
  body = instantiate_generic(gtd, args_int_str)
  assert_str_eq(body, "\{fst:I,snd:S}")
  cn = concrete_type_name("Pair", args_int_str)
  assert_str_eq(cn, "Pair__int__str")
