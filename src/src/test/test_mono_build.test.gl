test_mono_build u =
  src_max = "poly_max a b = match a > b\n  true -> a\n  _ -> b"
  src_main = "main =\n  x = poly_max(10, 20)\n  println(int_to_str(x))"
  parsed = parse_all_fns([src_max, src_main], 0)
  eng = mk_engine()
  register_builtins(eng)
  tc_pre_register(eng, parsed, 0)
  tc_results = tc_infer_loop(eng, parsed, 0, [])
  specs = mono_collect(parsed, tc_results, eng)
  assert_eq(glyph_array_len(specs), 1)
  match glyph_array_len(specs) > 0
    true ->
      s = specs[0]
      assert_str_eq(s.ms_orig, "poly_max")
      assert_str_eq(s.ms_spec, "poly_max__int")
    _ -> 0

