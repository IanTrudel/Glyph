test_match_field_offset_bug u =
  -- rec.other is at offset 0, rec.tag2 is at offset 1 (alphabetical)
  -- If the compiler reads offset 0 instead of 1, it reads rec.other (999)
  -- and treats that integer as an enum pointer -> segfault or wrong result
  tag = SVal("right")
  rec = {other: 0, tag2: tag}
  -- extract then match (the "workaround" the feedback mentions)
  t = rec.tag2
  r = match t
    SVal(s) -> s
    _ -> "wrong"
  assert_str_eq(r, "right")
  -- direct field match (the "broken" form)
  r2 = match rec.tag2
    SVal(s) -> s
    _ -> "wrong"
  assert_str_eq(r2, "right")
  0
