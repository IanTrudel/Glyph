test_mono_specialize u =
  src_id = "identity x = x"
  src_main = "main = println(int_to_str(identity(42)))"
  parsed = parse_all_fns([src_id, src_main], 0)
  eng = mk_engine()
  register_builtins(eng)
  tc_pre_register(eng, parsed, 0)
  tc_results = tc_infer_loop_sigs(eng, parsed, [], 0, [])
  za_fns = build_za_fns(parsed, 0, [])
  specs = mono_collect(parsed, tc_results, eng)
  spec_mirs = mono_compile_specs(specs, parsed, tc_results, za_fns, eng, [])
  assert_eq(glyph_array_len(spec_mirs), 1)
  match glyph_array_len(spec_mirs) > 0
    true ->
      mir = spec_mirs[0]
      assert_str_eq(mir.fn_name, "identity__int")
    _ -> 0
