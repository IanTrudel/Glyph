test_mono_name u =
  src = "identity x = x"
  parsed = parse_all_fns([src], 0)
  eng = mk_engine()
  register_builtins(eng)
  tc_pre_register(eng, parsed, 0)
  tc_results = tc_infer_loop(eng, parsed, 0, [])
  tr = tc_results[0]
  fn_ty = tr.fn_ty
  fn_node = pool_get(eng, fn_ty)
  _ = fn_node.tag
  body_ti = fn_node.n1
  int_ti = mk_tint(eng.ty_pool)
  concrete_fn_ti = mk_tfn(int_ti, int_ti, eng.ty_pool)
  var_map = mono_build_var_map(eng, body_ti, concrete_fn_ti, [])
  spec = mono_spec_name("identity", eng, var_map)
  assert_str_eq(spec, "identity__int")

