test_match_struct_field_basic u =
  -- Point2D has fields x=0 (offset 0), y=1 (offset 1) alphabetically
  p = {x: 1, y: 2}
  -- match on y (offset 1): if bug reads offset 0, gets x=1, returns "no"
  r = match p.y
    2 -> "yes"
    _ -> "no"
  assert_str_eq(r, "yes")
  -- match on x (offset 0): both correct and buggy reads give same result
  r2 = match p.x
    1 -> "yes"
    _ -> "no"
  assert_str_eq(r2, "yes")
  0
