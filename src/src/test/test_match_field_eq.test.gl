test_match_field_eq u =
  -- Test: match p.y == 99 { true -> ... } — does this read p.y or p.x?
  p = {x: 1, y: 99}
  r = match p.y == 99
    true -> "matched"
    _ -> "failed"
  assert_str_eq(r, "matched")
  -- Prove it's reading y not x: x=1 != 99, y=99 == 99
  p2 = {x: 99, y: 1}
  r2 = match p2.y == 99
    true -> "should_not_match"
    _ -> "correct"
  assert_str_eq(r2, "correct")
  0
