ctab_loop body gnames i acc =
  len = glyph_str_len(body)
  match i >= len
    true -> 0
    _ ->
      c = glyph_str_char_at(body, i)
      is_upper = c >= 65 && c <= 90
      match is_upper
        true ->
          app_end = ctab_try_read_app(body, gnames, i, acc)
          match app_end > i
            true -> ctab_loop(body, gnames, app_end, acc)
            _ -> ctab_loop(body, gnames, i + 1, acc)
        _ -> ctab_loop(body, gnames, i + 1, acc)
