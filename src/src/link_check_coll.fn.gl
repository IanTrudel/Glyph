link_check_coll rows app_db i n acc =
  match i >= n
    true -> acc
    _ ->
      row = rows[i]
      name = row[0]
      kind = row[1]
      sql = s5("SELECT COUNT(*) FROM def WHERE name='", sql_escape(name), "' AND kind='", sql_escape(kind), "'")
      cnt_rows = glyph_db_query_rows(app_db, sql)
      cnt = str_to_int(cnt_rows[0][0])
      _ = match cnt > 0
        true -> glyph_array_push(acc, s3(kind, " ", name))
        _ -> 0
      link_check_coll(rows, app_db, i + 1, n, acc)
