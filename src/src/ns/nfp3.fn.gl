nfp3 p =
  match glyph_str_eq(p, "json") == 1
    true -> "json"
    _ -> match glyph_str_eq(p, "jb") == 1
      true -> "json"
      _ -> match glyph_str_eq(p, "infer") == 1
        true -> "typeck"
        _ -> match glyph_str_eq(p, "subst") == 1
          true -> "typeck"
          _ -> match glyph_str_eq(p, "unify") == 1
            true -> "typeck"
            _ -> match glyph_str_eq(p, "env") == 1
              true -> "typeck"
              _ -> nfp4(p)
