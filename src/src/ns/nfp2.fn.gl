nfp2 p =
  match glyph_str_eq(p, "pdf") == 1
    true -> "parser"
    _ -> match glyph_str_eq(p, "tok") == 1
      true -> "tokenizer"
      _ -> match glyph_str_eq(p, "mcp") == 1
        true -> "mcp"
        _ -> match glyph_str_eq(p, "cmd") == 1
          true -> "cli"
          _ -> match glyph_str_eq(p, "tco") == 1
            true -> "tco"
            _ -> match glyph_str_eq(p, "blt") == 1
              true -> "builtin"
              _ -> nfp3(p)
