nfp6 p =
  match glyph_str_eq(p, "ex") == 1
    true -> "parser"
    _ -> match glyph_str_eq(p, "op") == 1
      true -> "parser"
      _ -> match glyph_str_eq(p, "pat") == 1
        true -> "parser"
        _ -> match glyph_str_eq(p, "nd") == 1
          true -> "parser"
          _ -> match glyph_str_eq(p, "tk") == 1
            true -> "tokenizer"
            _ -> nfp7(p)
