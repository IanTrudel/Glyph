nfp4 p =
  match glyph_str_eq(p, "inst") == 1
    true -> "typeck"
    _ -> match glyph_str_eq(p, "pool") == 1
      true -> "typeck"
      _ -> match glyph_str_eq(p, "walk") == 1
        true -> "lower"
        _ -> match glyph_str_eq(p, "wfv") == 1
          true -> "lower"
          _ -> nfp5(p)
