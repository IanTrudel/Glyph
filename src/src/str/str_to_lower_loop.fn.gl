str_to_lower_loop s i len acc =
  match i >= len
    true -> acc
    _ ->
      c = glyph_str_char_at(s, i)
      lowers = "abcdefghijklmnopqrstuvwxyz"
      ch = match c >= 65 && c <= 90
        true -> glyph_str_slice(lowers, c - 65, c - 64)
        _ -> glyph_str_slice(s, i, i + 1)
      str_to_lower_loop(s, i + 1, len, s2(acc, ch))
