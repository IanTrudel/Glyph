cg_params_list mir_fn i =
  pc = glyph_array_len(mir_fn.fn_params)
  match i >= pc
    true -> ""
    _ ->
      param_id = mir_fn.fn_params[i]
      decl = s3(gval_t(), " ", cg_local(param_id))
      rest = cg_params_list(mir_fn, i + 1)
      match i < pc - 1
        true -> s3(decl, ", ", rest)
        _ -> s2(decl, rest)
