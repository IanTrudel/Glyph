test_parse_or_pat u =
  src = "f x = match x\n  1 | 2 | 3 -> 10\n  _ -> 0"
  toks = tokenize(src)
  pool = []
  r = parse_fn_def(src, toks, 0, pool)
  assert(is_err(r) == 0)
  fn_node = pool[r.node]
  body = pool[fn_node.n1]
  assert_eq(body.kind, ex_match())
  arms = body.ns
  p0 = pool[arms[0]]
  assert_eq(p0.kind, pat_or())
  assert_eq(glyph_array_len(p0.ns), 3)
  0
