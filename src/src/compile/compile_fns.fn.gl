compile_fns sources i za_fns vmap =
  match i >= glyph_array_len(sources)
    true -> []
    _ ->
      mir = compile_fn_vm(sources[i], za_fns, vmap)
      rest = compile_fns(sources, i + 1, za_fns, vmap)
      collect_nested_lifted(rest, mir.fn_subs, 0)
      glyph_array_push(rest, mir)
      rest
