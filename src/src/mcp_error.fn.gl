mcp_error id code msg =
  sb = sb_new()
  sb_append(sb, "\{\"jsonrpc\":\"2.0\",\"id\":")
  sb_append(sb, int_to_str(id))
  sb_append(sb, ",\"error\":\{\"code\":")
  sb_append(sb, int_to_str(code))
  sb_append(sb, ",\"message\":")
  sb_append(sb, json_gen_str(msg))
  sb_append(sb, "}}")
  sb_build(sb)
