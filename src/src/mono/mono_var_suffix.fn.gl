mono_var_suffix eng var_map i =
  match i >= glyph_array_len(var_map)
    true -> ""
    _ ->
      type_ti = var_map[i + 1]
      name = mono_type_name(eng, type_ti)
      rest = mono_var_suffix(eng, var_map, i + 2)
      match glyph_str_len(rest) == 0
        true -> name
        _ -> s3(name, "_", rest)

