mono_bvm_map eng tnode concrete_ti acc =
  _ = tnode.tag
  match concrete_ti < 0
    true -> acc
    _ ->
      match concrete_ti >= glyph_array_len(eng.ty_pool)
        true -> acc
        _ ->
          cnode = pool_get(eng, concrete_ti)
          match cnode.tag == ty_map()
            true ->
              acc2 = mono_build_var_map(eng, tnode.n1, cnode.n1, acc)
              mono_build_var_map(eng, tnode.n2, cnode.n2, acc2)
            _ -> acc

