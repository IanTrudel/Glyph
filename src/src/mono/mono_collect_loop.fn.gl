mono_collect_loop parsed tc_results eng specs i =
  match i >= glyph_array_len(parsed)
    true -> specs
    _ ->
      pf = parsed[i]
      tr = match i < glyph_array_len(tc_results)
        true -> tc_results[i]
        _ -> {fn_tmap: [], fn_ty: 0 - 1, fn_ty_raw: []}
      specs2 = mono_collect_fn(pf, tr, i, parsed, tc_results, eng, specs)
      mono_collect_loop(parsed, tc_results, eng, specs2, i + 1)
