mono_bcm_callers spec caller_name i keys vals =
  match i >= glyph_array_len(spec.ms_caller_fns)
    true -> 0
    _ ->
      match str_eq(spec.ms_caller_fns[i], caller_name)
        true ->
          glyph_array_push(keys, spec.ms_caller_nis[i])
          glyph_array_push(vals, spec.ms_spec)
          mono_bcm_callers(spec, caller_name, i + 1, keys, vals)
        _ -> mono_bcm_callers(spec, caller_name, i + 1, keys, vals)

