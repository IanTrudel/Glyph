mono_fn_ty_idx parsed tc_results name i =
  match i >= glyph_array_len(parsed)
    true -> 0 - 1
    _ ->
      pf = parsed[i]
      match str_eq(pf.pf_name, name)
        true ->
          match i < glyph_array_len(tc_results)
            true -> (tc_results[i]).fn_ty
            _ -> 0 - 1
        _ -> mono_fn_ty_idx(parsed, tc_results, name, i + 1)

