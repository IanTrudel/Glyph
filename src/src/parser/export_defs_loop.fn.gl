export_defs_loop rows i n out_dir =
  match i >= n
    true -> 0
    _ ->
      row = rows[i]
      name = row[0]
      knd = row[1]
      body = row[2]
      gen = glyph_str_to_int(row[3])
      ns = row[4]
      dir = export_def_dir(out_dir, ns, gen)
      _ = glyph_system(s2("mkdir -p ", dir))
      path = export_def_path(out_dir, name, knd, gen, ns)
      glyph_write_file(path, s2(body, "\n"))
      export_defs_loop(rows, i+1, n, out_dir)
