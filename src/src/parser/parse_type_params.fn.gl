parse_type_params body =
  len = glyph_str_len(body)
  match len == 0
    true -> {tp_params: [], tp_rest: body}
    _ ->
      c0 = glyph_str_char_at(body, 0)
      match c0 == 60
        true ->
          params = []
          rest_i = ptp_loop(body, 1, params)
          rest = match rest_i >= 0
            true -> glyph_str_slice(body, rest_i, len)
            _ -> body
          {tp_params: params, tp_rest: rest}
        _ -> {tp_params: [], tp_rest: body}
