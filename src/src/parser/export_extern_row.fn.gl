export_extern_row row =
  name = row[0]
  sym = row[1]
  lib = row[2]
  sig = row[3]
  lib_sql = match glyph_str_len(lib) == 0
    true -> "NULL"
    _ -> s3("'", sql_escape(lib), "'")
  s2("INSERT OR IGNORE INTO extern_ (name,symbol,lib,sig) VALUES ('",
     s7(sql_escape(name), "','", sql_escape(sym), "',", lib_sql, ",'", s2(sql_escape(sig), "');\n")))
