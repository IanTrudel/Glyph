test_parse_match u =
  src = "f x = match x\n  1 -> 10\n  2 -> 20\n  _ -> 30"
  toks = tokenize(src)
  pool = []
  r = parse_fn_def(src, toks, 0, pool)
  assert(is_err(r) == 0)
  fn_node = pool[r.node]
  body = pool[fn_node.n1]
  assert_eq(body.kind, ex_match())
  assert_eq(glyph_array_len(body.ns), 9)
  0
