parse_record_with_base src tokens pos pool base_idx =
  match cur_kind(tokens, pos) == tk_rbrace()
    true ->
      idx = pool_push(pool, mk_node(ex_record(), 0, "", base_idx, 0 - 1, 0 - 1, []))
      mk_result(idx, pos + 1)
    _ ->
      pairs = []
      parse_record_loop_base(src, tokens, pos, pool, pairs, base_idx)
