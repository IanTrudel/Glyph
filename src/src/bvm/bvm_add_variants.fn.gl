bvm_add_variants variants i result body =
  match i >= glyph_array_len(variants)
    true -> 0
    _ ->
      vname = variants[i]
      ptypes = parse_variant_payload_tags(body, vname)
      pnames = parse_variant_payload_names(body, vname)
      entry = {ve_name: vname, ve_disc: i, ve_ptypes: ptypes, ve_pnames: pnames}
      glyph_array_push(result, entry)
      bvm_add_variants(variants, i + 1, result, body)
