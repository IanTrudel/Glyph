cg_cov_collect_loop mirs i acc =
  match i >= glyph_array_len(mirs)
    true -> 0
    _ ->
      mir = mirs[i]
      nm = mir.fn_name
      match is_runtime_fn(nm) == 1
        true -> 0
        _ ->
          glyph_array_push(acc, nm)
          0
      cg_cov_collect_subs(mir.fn_subs, 0, acc)
      cg_cov_collect_loop(mirs, i + 1, acc)

