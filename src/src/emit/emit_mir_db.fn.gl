emit_mir_db db_path =
  db = glyph_db_open(db_path)
  sources = read_fn_defs(db)
  externs = read_externs(db)
  type_rows = read_type_defs(db)
  glyph_db_close(db)
  parsed = parse_all_fns(sources, 0)
  za_fns = build_za_fns(parsed, 0, [])
  struct_map = build_struct_map(type_rows)
  vmap = build_variant_map(type_rows)
  mirs = compile_fns_parsed(parsed, 0, za_fns, [], false, vmap)
  fix_all_field_offsets(mirs, struct_map)
  fix_extern_calls(mirs, externs)
  mir_pp_fns(mirs, 0)
  0
