infer_map_pairs eng ast pairs k_ty v_ty i =
  match i >= glyph_array_len(pairs)
    true -> 0
    _ ->
      kt = infer_expr(eng, ast, pairs[i])
      vt = infer_expr(eng, ast, pairs[i + 1])
      unify(eng, kt, k_ty)
      unify(eng, vt, v_ty)
      infer_map_pairs(eng, ast, pairs, k_ty, v_ty, i + 2)

