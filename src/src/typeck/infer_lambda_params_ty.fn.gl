infer_lambda_params_ty eng ast params i =
  match i >= glyph_array_len(params)
    true -> []
    _ ->
      pnode = ast[params[i]]
      pt = subst_fresh(eng)
      env_insert(eng, pnode.sval, pt)
      rest = infer_lambda_params_ty(eng, ast, params, i + 1)
      glyph_array_push(rest, pt)
      rest
