tc_rc_mk_record eng fields ctypes i field_ns =
  match i >= glyph_array_len(fields)
    true ->
      rest = subst_fresh_var(eng)
      mk_trecord(field_ns, rest, eng.ty_pool)
    _ ->
      fname = fields[i]
      ctype = ctypes[i]
      ft = tc_rc_field_type(eng, ctype)
      fi = mk_tfield(fname, ft, eng.ty_pool)
      glyph_array_push(field_ns, fi)
      tc_rc_mk_record(eng, fields, ctypes, i + 1, field_ns)
