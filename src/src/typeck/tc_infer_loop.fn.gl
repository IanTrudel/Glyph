tc_infer_loop eng parsed i acc =
  match i >= glyph_array_len(parsed)
    true -> acc
    _ ->
      pf = parsed[i]
      err_before = glyph_array_len(eng.errors)
      result = match pf.pf_fn_idx >= 0
        true ->
          ast_len = glyph_array_len(pf.pf_ast)
          eng_set_tmap(eng, ast_len)
          ty = infer_fn_def(eng, pf.pf_ast, pf.pf_fn_idx)
          gen_ty = generalize(eng, ty)
          _ = env_insert(eng, pf.pf_name, gen_ty)
          tm = eng.tmap[0]
          raw_tm = mono_copy_arr(tm)
          resolve_tmap(eng, tm)
          resolved = match gen_ty >= 0
            true -> subst_resolve(eng, gen_ty)
            _ -> 0 - 1
          {fn_tmap: tm, fn_ty: resolved, fn_ty_raw: raw_tm}
        _ -> {fn_tmap: [], fn_ty: 0 - 1, fn_ty_raw: []}
      err_after = glyph_array_len(eng.errors)
      match err_after > err_before
        true -> eprintln(s2("  [tc_err] ", pf.pf_name))
        _ -> 0
      glyph_array_push(acc, result)
      tc_infer_loop(eng, parsed, i + 1, acc)
