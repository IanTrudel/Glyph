tc_rc_param_type eng pname struct_map =
  tag = type_name_tag(pname)
  match tag == 4
    true -> mk_tstr(eng.ty_pool)
    _ -> match tag == 3
      true -> mk_tfloat(eng.ty_pool)
      _ ->
        sm = tc_rc_find_struct(struct_map, pname, 0)
        match glyph_array_len(sm) > 0
          true -> tc_rc_mk_record(eng, sm[1], sm[2], 0, [])
          _ -> subst_fresh(eng)
