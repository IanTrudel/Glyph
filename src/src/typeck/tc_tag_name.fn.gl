tc_tag_name tag =
  match tag
    _ ? tag == ty_int() -> "I"
    _ ? tag == ty_uint() -> "U"
    _ ? tag == ty_float() -> "F"
    _ ? tag == ty_str() -> "S"
    _ ? tag == ty_bool() -> "B"
    _ ? tag == ty_void() -> "V"
    _ ? tag == ty_never() -> "N"
    _ ? tag == ty_fn() -> "Fn"
    _ ? tag == ty_array() -> "[T]"
    _ ? tag == ty_opt() -> "?T"
    _ ? tag == ty_res() -> "!T"
    _ ? tag == ty_record() -> "\{..}"
    _ -> "?"

