infer_ctor_bind_fresh eng ast sub_pats i =
  match i >= glyph_array_len(sub_pats)
    true -> 0
    _ ->
      sp = ast[sub_pats[i]]
      match sp.kind == pat_ident()
        true ->
          pt = subst_fresh(eng)
          env_insert(eng, sp.sval, pt)
          0
        _ -> 0
      infer_ctor_bind_fresh(eng, ast, sub_pats, i + 1)
