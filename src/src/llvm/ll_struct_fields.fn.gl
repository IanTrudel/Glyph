ll_struct_fields fields types n i =
  match i >= n
    true -> ""
    _ ->
      t = match glyph_array_len(types) > i
        true -> ll_field_lltype(glyph_arr_get_str(types, i))
        _ -> "i64"
      rest = ll_struct_fields(fields, types, n, i + 1)
      match i < n - 1
        true -> s3(t, ", ", rest)
        _ -> s2(t, rest)
