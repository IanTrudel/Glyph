ll_array_elem_stores ops d strs fn_name data_ptr i =
  match i >= glyph_array_len(ops)
    true -> ""
    _ ->
      pair = ll_load_operand(ops[i], d, i + 30, strs, fn_name)
      slot = s3("%eslot_", itos(d), s2("_", itos(i)))
      gep = s7("  ", slot, " = getelementptr i64, ptr ", data_ptr, ", i64 ", itos(i), "\n")
      st = s5("  store i64 ", pair[1], ", ptr ", slot, "\n")
      s4(pair[0], gep, st, ll_array_elem_stores(ops, d, strs, fn_name, data_ptr, i + 1))
