ll_is_cmp_op op =
  match op == mir_eq()
    true -> 1
    _ -> match op == mir_neq()
      true -> 1
      _ -> match op == mir_lt()
        true -> 1
        _ -> match op == mir_gt()
          true -> 1
          _ -> match op == mir_lt_eq()
            true -> 1
            _ -> match op == mir_gt_eq()
              true -> 1
              _ -> 0
