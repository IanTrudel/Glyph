tmap_resolve_tag eng ti =
  match ti < 0
    true -> 0 - 1
    _ ->
      pool = eng.ty_pool
      match ti >= glyph_array_len(pool)
        true -> 0 - 1
        _ ->
          resolved = subst_resolve(eng, ti)
          match resolved < 0
            true -> 0 - 1
            _ ->
              match resolved >= glyph_array_len(pool)
                true -> 0 - 1
                _ -> (pool[resolved]).tag
