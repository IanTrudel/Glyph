test_nested_guards u =
  x = 1
  y = 20
  r1 = match x
    _ ? x == 1 -> match y
      _ ? y == 10 -> 100
      _ ? y == 20 -> 200
      _ -> 0
    _ ? x == 2 -> 300
    _ -> 0 - 1
  assert_eq(r1, 200)
  a = 2
  r2 = match a
    _ ? a == 1 -> 100
    _ ? a == 2 -> 300
    _ -> 0 - 1
  assert_eq(r2, 300)
