test_parse_precedence u =
  src = "f x = 1 + 2 * 3"
  toks = tokenize(src)
  pool = []
  r = parse_fn_def(src, toks, 0, pool)
  assert(is_err(r) == 0)
  fn_node = pool[r.node]
  body = pool[fn_node.n1]
  assert_eq(body.kind, ex_binary())
  assert_eq(body.ival, op_add())
  rhs = pool[body.n2]
  assert_eq(rhs.kind, ex_binary())
  assert_eq(rhs.ival, op_mul())
  0
