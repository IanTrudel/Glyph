measure_indent_loop src pos count len =
  match pos < len
    true ->
      match is_space(glyph_str_char_at(src, pos))
        true ->
          inc = match glyph_str_char_at(src, pos)
            9 -> 4
            _ -> 1
          measure_indent_loop(src, pos + 1, count + inc, len)
        _ -> count * 1000000 + pos
    _ -> count * 1000000 + pos
