unaryop_type eng op operand =
  t = ty_tag(eng.ty_pool, operand)
  match op == op_neg()
    true ->
      match t == ty_int()
        true -> mk_tint(eng.ty_pool)
        _ -> match t == ty_float()
          true -> mk_ty_prim(ty_float(), eng.ty_pool)
          _ -> 0 - 1
    _ -> match op == op_not()
      true -> mk_tbool(eng.ty_pool)
      _ -> 0 - 1
