test_or_guard u =
  x = 2
  r1 = match x
    _ ? x == 1 || x == 2 || x == 3 -> 10
    _ ? x == 10 || x == 20 -> 20
    _ -> 0
  assert_eq(r1, 10)
  y = 20
  r2 = match y
    _ ? y == 1 || y == 2 || y == 3 -> 10
    _ ? y == 10 || y == 20 -> 20
    _ -> 0
  assert_eq(r2, 20)
  z = 99
  r3 = match z
    _ ? z == 1 || z == 2 || z == 3 -> 10
    _ ? z == 10 || z == 20 -> 20
    _ -> 0
  assert_eq(r3, 0)
