lower_let_destr ctx ast node =
  val = lower_expr(ctx, ast, node.n1)
  tmp = mir_alloc_local(ctx, "_d")
  mir_emit_use(ctx, tmp, val)
  ot = op_type(ctx, val)
  tt = tctx_query(ctx.tctx, node.n1)
  ty = match ot > 0
    true -> ot
    _ -> match tt > 0
      true -> tt
      _ -> 0
  mir_set_lt(ctx, tmp, ty)
  names = node.ns
  lld_loop(ctx, names, 0, tmp)
  mk_op_unit()

