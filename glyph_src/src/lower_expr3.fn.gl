lower_expr3 ctx ast node k =
  match k
    _ ? k == ex_float_lit() ->
      dest = mir_alloc_local(ctx, "")
      mir_set_lt(ctx, dest, 3)
      mir_emit_use(ctx, dest, mk_op_float(node.sval))
      mk_op_local(dest)
    _ ? k == ex_propagate() -> lower_propagate(ctx, ast, node)
    _ ? k == ex_unwrap() -> lower_unwrap(ctx, ast, node)
    _ -> mk_op_unit()
