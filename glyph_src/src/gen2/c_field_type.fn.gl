c_field_type spec =
  match glyph_str_eq(spec, "i8")
    true -> "int8_t"
    _ -> match glyph_str_eq(spec, "u8")
      true -> "uint8_t"
      _ -> match glyph_str_eq(spec, "i16")
        true -> "int16_t"
        _ -> match glyph_str_eq(spec, "u16")
          true -> "uint16_t"
          _ -> match glyph_str_eq(spec, "i32")
            true -> "int32_t"
            _ -> match glyph_str_eq(spec, "u32")
              true -> "uint32_t"
              _ -> c_field_type2(spec)
