insert_deps db_path pairs =
  n = glyph_array_len(pairs)
  match n == 0
    true -> 0
    _ ->
      db = glyph_db_open(db_path)
      glyph_db_exec(db, "DELETE FROM dep WHERE edge = 'calls'")
      insert_dep_loop(db, pairs, 0)
      glyph_db_close(db)
      println(s2("Tracked ", s2(itos(n / 2), " dependency edges")))
      0
