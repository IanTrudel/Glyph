str_lt_loop a b i la lb =
  match i >= la
    true -> match i >= lb
      true -> 0
      _ -> 1
    _ -> match i >= lb
      true -> 0
      _ ->
        ca = glyph_str_char_at(a, i)
        cb = glyph_str_char_at(b, i)
        match ca < cb
          true -> 1
          _ -> match ca > cb
            true -> 0
            _ -> str_lt_loop(a, b, i + 1, la, lb)
